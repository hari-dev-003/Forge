# ─────────────────────────────────────────────────────────────
# Forge — Backend environment (AWS: DynamoDB + S3 + Cognito)
# Copy to `.env` and fill in real values. There is no local fallback.
# In Lambda, set these as function env vars (or SSM/Secrets Manager).
# ─────────────────────────────────────────────────────────────

# Use "production" for deployed environments.
NODE_ENV=production
PORT=4000
API_PREFIX=/api
# Comma-separated allowed origins — your Amplify app URL. Avoid "*" in production.
CORS_ORIGIN=https://your-app.amplifyapp.com

# ── AWS ──────────────────────────────────────────────────────
# Credentials come from the IAM role / environment. DO NOT put access keys here.
AWS_REGION=ap-south-1

# DynamoDB single table — keys pk/sk, plus GSI1 (gsi1pk/gsi1sk) and GSI2 (gsi2pk/gsi2sk)
DDB_TABLE_NAME=Forge

# S3 bucket for meeting photos — keep it PRIVATE. Uploads use presigned PUT,
# reads use presigned GET (no public access). Bucket CORS must allow PUT + GET.
S3_BUCKET=forge-photos
S3_PRESIGN_EXPIRES=300
S3_VIEW_EXPIRES=3600

# ── Cognito ──────────────────────────────────────────────────
# App client must have ALLOW_ADMIN_USER_PASSWORD_AUTH enabled.
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
# Only set if the app client was created WITH a secret:
COGNITO_CLIENT_SECRET=
COGNITO_REGION=ap-south-1

# ── First admin (created by `npm run bootstrap`) ─────────────
BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=System Admin
